---
import type { Dictionary } from "../../i18n/utils";
import SectionEyebrow from "../ui/SectionEyebrow.astro";
import { experience } from "../../data/experience";

interface Props {
  t: Dictionary;
}

const { t } = Astro.props;
---

<section id="experience" class="section py-20" data-reveal>
  <SectionEyebrow text={t.exp_eyebrow} i18nKey="exp_eyebrow" />
  <h2 class="font-sans fw-bold text-3xl tracking-tight text-primary mb-8" data-i18n="exp_title">
    {t.exp_title}
  </h2>

  <div class="flex flex-col">
    {
      experience.map((entry) => (
        <div class="timeline-row">
          <div class="flex items-start gap-3 mt-2">
            <span
              class:list={["dot", entry.active ? "dot--active" : "dot--past"]}
            />
            <div class="font-mono text-12 uppercase tracking-wide text-secondary leading-snug" data-i18n={entry.periodKey}>
              {t[entry.periodKey]}
            </div>
          </div>
          <div>
            <div class="flex items-baseline gap-3 flex-wrap">
              <span class="font-sans fw-bold text-xl text-primary" data-i18n={entry.roleKey}>
                {t[entry.roleKey]}
              </span>
              {entry.company && (
                <span class="font-mono text-13 text-accent">
                  {entry.company}
                </span>
              )}
            </div>
            <p class="font-sans text-base text-secondary leading-relaxed max-w-md mt-2" data-i18n={entry.descKey}>
              {t[entry.descKey]}
            </p>
          </div>
        </div>
      ))
    }
  </div>
</section>
