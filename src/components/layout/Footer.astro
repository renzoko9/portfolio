---
import type { Dictionary } from '../../i18n/utils';
import Icon from '../ui/Icon.astro';
import { socialLinks } from '../../data/social';

interface Props {
  t: Dictionary;
}

const { t } = Astro.props;
---

<footer class="section flex items-center justify-between gap-6 flex-wrap py-12 pb-16">
  <div class="flex flex-col gap-1">
    <span class="font-mono fw-bold text-14 tracking-widest text-primary">RC<span class="text-accent">.</span></span>
    <span class="font-mono text-12 text-tertiary">{t.footer_built}</span>
  </div>

  <div class="flex gap-4">
    {socialLinks.map((social) => (
      <a href={social.href} aria-label={social.label} class="icon-link" target="_blank" rel="noopener">
        <Icon name={social.id} size={20} />
      </a>
    ))}
  </div>
</footer>
